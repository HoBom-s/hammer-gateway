{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {TraceId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_AT_LEAST_32_CHARS!",
    "Issuer": "hammer-user",
    "Audience": "hammer"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "hammer-user",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "hammer-user",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "auctions-route": {
        "ClusterId": "hammer-auction",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/auctions/{**catch-all}"
        }
      },
      "collectors-route": {
        "ClusterId": "hammer-collector",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/collectors/{**catch-all}"
        }
      },
      "support-route": {
        "ClusterId": "hammer-support",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/support/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "hammer-user": {
        "Destinations": {
          "primary": {
            "Address": "http://hammer-user:5001/"
          }
        }
      },
      "hammer-auction": {
        "Destinations": {
          "primary": {
            "Address": "http://hammer-auction:5002/"
          }
        }
      },
      "hammer-collector": {
        "Destinations": {
          "primary": {
            "Address": "http://hammer-collector:5003/"
          }
        }
      },
      "hammer-support": {
        "Destinations": {
          "primary": {
            "Address": "http://hammer-support:5004/"
          }
        }
      }
    }
  }
}
